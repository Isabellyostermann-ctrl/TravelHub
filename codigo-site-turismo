    with aba_read_u:
        usuarios_db = list(colecao_usuarios.find())
        if usuarios_db:
            df_u = pd.DataFrame(usuarios_db)
            df_u['_id'] = df_u['_id'].astype(str)
            st.dataframe(df_u, use_container_width=True)

    with aba_update_u:
        usuarios_lista = list(colecao_usuarios.find())
        if usuarios_lista:
            opcoes_u = {str(u["_id"]): u.get("nome", "") for u in usuarios_lista}
            id_sel_u = st.selectbox("Editar Usuário", options=list(opcoes_u.keys()), format_func=lambda x: opcoes_u[x])
            user_atual = colecao_usuarios.find_one({"_id": ObjectId(id_sel_u)})
            with st.form("form_update_user"):
                novo_nome_u = st.text_input("Nome", value=user_atual.get("nome", ""))
                if st.form_submit_button("Atualizar"):
                    colecao_usuarios.update_one({"_id": ObjectId(id_sel_u)}, {"$set": {"nome": novo_nome_u}})
                    st.success("Atualizado!")

    with aba_delete_u:
        usuarios_del = list(colecao_usuarios.find())
        if usuarios_del:
            opcoes_del_u = {str(u["_id"]): u.get("nome", "") for u in usuarios_del}
            id_del_u = st.selectbox("Excluir Usuário", options=list(opcoes_del_u.keys()), format_func=lambda x: opcoes_del_u[x])
            if st.button("Excluir", type="primary"):
                colecao_usuarios.delete_one({"_id": ObjectId(id_del_u)})
                st.success("Excluído!")


# TELA 4: CRUD DE DICAS

elif menu == "CRUD - Dicas":
    st.title("💡 Gerenciamento de Dicas")
