# ==========================================
# FUNÇÕES DO REDIS (NOVAS)
# ==========================================
def favoritar_destino(usuario, nome_destino):
    chave = f"favoritos:{usuario}"
    r.sadd(chave, nome_destino)

def listar_favoritos(usuario):
    chave = f"favoritos:{usuario}"
    return r.smembers(chave)

def registrar_visto(usuario, nome_destino):
    chave = f"vistos:{usuario}"
    r.sadd(chave, nome_destino)

def destino_e_inedito(usuario, nome_destino):
    chave = f"vistos:{usuario}"
    return not r.sismember(chave, nome_destino)

