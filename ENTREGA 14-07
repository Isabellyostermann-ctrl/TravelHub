            {"$set": {"total_dicas_escritas": {"$size": "$dicas_feitas"}}},
            {"$project": {
                "_id": 1,
                "nome": 1,
                "total_dicas_escritas": 1,
                "status_engajamento": {"$cond": [{"$gt": ["$total_dicas_escritas", 0]}, "Usuario Ativo", "Usuario Fantasma"]}
            }},
            {"$merge": {
                "into": "relatorio_engajamento",
                "whenMatched": "replace",
                "whenNotMatched": "insert"
            }}
        ]
        
